{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/webhook", "dest": "/api/webhook.js" },
    { "src": "/health", "dest": "/api/health.js" },
    { "src": "/stats", "dest": "/api/stats.js" },
    { "src": "/diag", "dest": "/api/diag.js" },
    { "src": "/", "dest": "/public/index.html" }
  ]
}
